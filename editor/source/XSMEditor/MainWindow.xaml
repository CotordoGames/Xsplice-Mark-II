<Window x:Class="XSMEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:XSMEditor"
        Title="XSM Editor — XSPLICE Mark II"
        Width="1280" Height="800"
        Background="{StaticResource Bg0Brush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI">

    <DockPanel>

        <!-- ── TOOLBAR ── -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource Bg1Brush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,5">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <TextBlock Text="XSM" FontFamily="Segoe UI" FontWeight="Bold" FontSize="14"
                           Foreground="{StaticResource Accent2Brush}" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="0,0,6,0"/>
                <Button Content="New" Click="OnNew" Margin="0,0,3,0"/>
                <Button Content="Open" Click="OnOpen" Margin="0,0,3,0"/>
                <Button Content="Save" Click="OnSave" Margin="0,0,3,0"/>
                <Button Content="Save As" Click="OnSaveAs" Margin="0,0,3,0"/>

                <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>
                <Button x:Name="BtnUndo" Content="↩ Undo" Click="OnUndo" IsEnabled="False" Margin="0,0,3,0"/>
                <Button x:Name="BtnRedo" Content="↪ Redo" Click="OnRedo" IsEnabled="False" Margin="0,0,3,0"/>

                <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>
                <Button x:Name="BtnModeTile" Content="Tiles" Click="OnModeTile"
                        Background="{StaticResource Accent4Brush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        Foreground="{StaticResource TextBrush}" Margin="0,0,3,0"/>
                <Button x:Name="BtnModeColl" Content="Collision" Click="OnModeColl" Margin="0,0,3,0"/>

                <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>
                <Button x:Name="BtnGrid" Content="Grid ✓" Click="OnToggleGrid" Margin="0,0,3,0"/>
                <Button Content="Reset View" Click="OnResetView" Margin="0,0,3,0"/>

                <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>
                <Button Content="−" Click="OnZoomOut" Margin="0,0,3,0" Width="24"/>
                <TextBlock x:Name="ZoomLabel" Text="2×" VerticalAlignment="Center"
                           Foreground="{StaticResource Accent2Brush}" Margin="0,0,3,0" MinWidth="24" TextAlignment="Center"/>
                <Button Content="+" Click="OnZoomIn" Margin="0,0,3,0" Width="24"/>

                <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>
                <TextBlock x:Name="StatusLabel" Text="ready" VerticalAlignment="Center"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
            </StackPanel>
        </Border>

        <!-- ── MAIN AREA ── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT PANEL ── -->
            <Border Grid.Column="0"
                    Background="{StaticResource Bg1Brush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <!-- Header -->
                        <TextBlock Text="XSM HEADER" Style="{StaticResource PanelTitle}"/>
                        <Label Content="Name (16 chars)"/>
                        <TextBox x:Name="TxtName" TextChanged="OnHeaderChanged" Margin="0,0,0,6"/>
                        <Label Content="Author (16 chars)"/>
                        <TextBox x:Name="TxtAuthor" TextChanged="OnHeaderChanged" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition Width="6"/><ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="W (tiles)"/>
                                <TextBox x:Name="TxtWidth" TextChanged="OnSizeChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="H (tiles)"/>
                                <TextBox x:Name="TxtHeight" TextChanged="OnSizeChanged"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="Apply Resize" Click="OnResize" Margin="0,0,0,10"/>

                        <Separator Background="{StaticResource BorderBrush}" Margin="0,4,0,10"/>

                        <!-- Assets -->
                        <TextBlock Text="ASSETS" Style="{StaticResource PanelTitle}"/>
                        <Label Content="Tilemap (tm{n}.png)"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="6"/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                            <ComboBox x:Name="CmbTilemap" Grid.Column="0" SelectionChanged="OnTilemapChanged"/>
                            <TextBlock x:Name="TxtTilemapIdx" Grid.Column="2" Text="#0"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center"/>
                        </Grid>
                        <Label Content="BG Image (bg{n}.png)"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="6"/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                            <ComboBox x:Name="CmbBg" Grid.Column="0" SelectionChanged="OnBgChanged"/>
                            <TextBlock x:Name="TxtBgIdx" Grid.Column="2" Text="#0"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center"/>
                        </Grid>
                        <Label Content="BGM"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="6"/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                            <ComboBox x:Name="CmbBgm" Grid.Column="0" SelectionChanged="OnBgmChanged"/>
                            <TextBlock x:Name="TxtBgmIdx" Grid.Column="2" Text="#0"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Background="{StaticResource BorderBrush}" Margin="0,4,0,10"/>

                        <!-- Tileset -->
                        <TextBlock Text="TILESET" Style="{StaticResource PanelTitle}"/>
                        <TextBlock x:Name="TxtTileIdx" Foreground="{StaticResource Accent2Brush}"
                                   FontSize="10" Margin="0,0,0,4">Tile: 0</TextBlock>
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Background="{StaticResource Bg0Brush}" MaxHeight="300">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <local:TilesetPanel x:Name="TilesetView"/>
                            </ScrollViewer>
                        </Border>

                        <Separator Background="{StaticResource BorderBrush}" Margin="0,10,0,10"/>

                        <!-- Tools -->
                        <TextBlock Text="TOOLS" Style="{StaticResource PanelTitle}"/>
                        <UniformGrid Columns="3" Margin="0,0,0,4">
                            <Button x:Name="BtnDraw"  Content="Draw"  Style="{StaticResource ToolButton}" Click="OnToolDraw"
                                    Background="{StaticResource Accent4Brush}" BorderBrush="{StaticResource AccentBrush}"
                                    Foreground="{StaticResource TextBrush}" Margin="0,0,3,3"/>
                            <Button x:Name="BtnErase" Content="Erase" Style="{StaticResource ToolButton}" Click="OnToolErase" Margin="0,0,3,3"/>
                            <Button x:Name="BtnFill"  Content="Fill"  Style="{StaticResource ToolButton}" Click="OnToolFill"  Margin="0,0,0,3"/>
                            <Button x:Name="BtnPick"  Content="Pick"  Style="{StaticResource ToolButton}" Click="OnToolPick"  Margin="0,0,3,3"/>
                            <Button x:Name="BtnRect"  Content="Rect"  Style="{StaticResource ToolButton}" Click="OnToolRect"  Margin="0,0,3,3"/>
                        </UniformGrid>
                        <TextBlock Text="MMB/Space+drag: pan  ·  Scroll: zoom"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="9" TextWrapping="Wrap"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── MAP CANVAS ── -->
            <Border Grid.Column="1" Background="{StaticResource Bg0Brush}" ClipToBounds="True">
                <local:MapCanvas x:Name="Canvas" Cursor="Cross"
                                 Focusable="True"/>
            </Border>

            <!-- ── RIGHT PANEL ── -->
            <Border Grid.Column="2"
                    Background="{StaticResource Bg1Brush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,0">
                <DockPanel>

                    <!-- Collision box controls -->
                    <StackPanel DockPanel.Dock="Top" Margin="10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="COLLISION BOXES" Style="{StaticResource PanelTitle}" Margin="0"/>
                            <Border Background="{StaticResource Accent4Brush}" CornerRadius="3"
                                    Padding="4,1" Margin="6,0,0,0">
                                <TextBlock x:Name="TxtBoxCount" Text="0"
                                           Foreground="{StaticResource Accent2Brush}" FontSize="9"/>
                            </Border>
                        </StackPanel>
                        <UniformGrid Columns="3">
                            <Button Content="+ Add" Click="OnAddBox" Style="{StaticResource ToolButton}" Margin="0,0,3,0"/>
                            <Button Content="Dupe"  Click="OnDupeBox" Style="{StaticResource ToolButton}" Margin="0,0,3,0"/>
                            <Button Content="Del"   Click="OnDeleteBox" Style="{StaticResource ToolButton}"
                                    Foreground="{StaticResource TextMutedBrush}"/>
                        </UniformGrid>
                        <TextBlock Text="Draw rect on canvas in Collision mode, or add manually."
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="9"
                                   TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>

                    <Separator DockPanel.Dock="Top" Background="{StaticResource BorderBrush}"/>

                    <!-- box props -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="10" x:Name="BoxPropsPanel" Visibility="Collapsed">
                        <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtBoxIdx" Style="{StaticResource PanelTitle}" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="6"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="X (tiles)"/>
                                <TextBox x:Name="BoxX" TextChanged="OnBoxPropChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="Y (tiles)"/>
                                <TextBox x:Name="BoxY" TextChanged="OnBoxPropChanged"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="6"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="W (tiles)"/>
                                <TextBox x:Name="BoxW" TextChanged="OnBoxPropChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="H (tiles)"/>
                                <TextBox x:Name="BoxH" TextChanged="OnBoxPropChanged"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- box list -->
                    <ListBox x:Name="BoxList"
                             Background="{StaticResource Bg0Brush}"
                             Foreground="{StaticResource TextBrush}"
                             BorderThickness="0"
                             SelectionChanged="OnBoxListSelected"
                             FontFamily="Segoe UI" FontSize="11">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter Property="Padding" Value="8,5"/>
                                <Setter Property="Margin" Value="4,2"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Accent4Brush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
